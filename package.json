{
  "name": "sptc",
  "version": "1.0.0",
  "description": "Multi-terminal app with auto-grid layout",
  "main": "main.js",
  "scripts": {
    "build": "esbuild src/renderer.js --bundle --outfile=dist/renderer.js --platform=browser --format=iife",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^41.0.2",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4"
  },
  "build": {
    "appId": "com.sptc.multi-terminal",
    "productName": "SPTC",
    "win": {
      "target": "portable"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "dist/**",
      "node_modules/@xterm/**"
    ],
    "asar": false
  }
}
